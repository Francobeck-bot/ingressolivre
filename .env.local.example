# ─────────────────────────────────────────────────────────────────────────────
# IngressoLivre — Environment Variables
# Copy this file to .env.local and fill in your real credentials.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Find these at: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>

# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Find at: https://www.mercadopago.com.br/developers/panel/app
# Use a TEST-... key for development; PROD-... for production
MERCADOPAGO_ACCESS_TOKEN=TEST-<your-access-token>

# ── App ───────────────────────────────────────────────────────────────────────
# No trailing slash. Used for OAuth callbacks and webhook URLs.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Supabase Service Role (server-only, NEVER expose to client) ───────────────
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Admin panel ───────────────────────────────────────────────────────────────
# Comma-separated list of email addresses allowed to access /admin
NEXT_PUBLIC_ADMIN_EMAILS=seu@email.com

# ── Vercel Cron secret ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
# Set this same value in Vercel Dashboard → Project Settings → Env Vars
CRON_SECRET=<random-secret>
